#!/usr/bin/env bash
# =============================================================================
# 02login - 批量将已注册的 OpenAI 账号登录到 Codexbar
#
# 用法:
#   ./02login [数量]
#   COUNT=50 ./02login
#   INTERVAL_SECS=150 ./02login 20
#   EMAIL_FILTER="xxx@icloud.com" ./02login 1   # 只登录指定邮箱
#
# 环境变量:
#   COUNT          - 本次登录数量，默认读取 CSV 中所有 pending 账号
#   INTERVAL_SECS  - 每次登录间隔秒数，默认 150
#   CSV_PATH       - codex.csv 路径，默认 ../codex.csv
#   EMAIL_FILTER   - 只处理指定邮箱（可选）
# =============================================================================

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

IMPORT_SCRIPT="$ROOT_DIR/scripts/import_openai_account_to_codexbar.sh"
CSV_SHADOW_HELPER="$ROOT_DIR/scripts/codex_csv_shadow.sh"

COUNT="${COUNT:-}"
INTERVAL_SECS="${INTERVAL_SECS:-150}"
CSV_PATH="${CSV_PATH:-$ROOT_DIR/codex.csv}"
EMAIL_FILTER="${EMAIL_FILTER:-}"

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    printf '❌ 缺少命令: %s\n' "$1" >&2
    exit 127
  }
}

update_csv_status() {
  local email="$1" password="$2" status="$3"
  python3 - "$CSV_PATH" "$email" "$password" "$status" <<'PY'
import csv, sys
path, email, password, status = sys.argv[1:]
with open(path, "r", encoding="utf-8", newline="") as fh:
    rows = list(csv.reader(fh))
if not rows:
    rows = [["email", "password", "status", "url"]]
target_index = None
if email:
    for idx in range(len(rows) - 1, 0, -1):
        row = rows[idx]
        while len(row) < 4: row.append("")
        if row[0] == email:
            target_index = idx; break
if target_index is None:
    rows.append([email, password, status, ""])
else:
    existing = rows[target_index]
    while len(existing) < 4: existing.append("")
    rows[target_index] = [
        email or existing[0],
        password if password != "" else existing[1],
        status if status != "" else existing[2],
        existing[3],
    ]
with open(path, "w", encoding="utf-8", newline="") as fh:
    csv.writer(fh).writerows(rows)
PY
}

get_pending_accounts() {
  python3 - "$CSV_PATH" "$EMAIL_FILTER" <<'PY'
import csv, json, os, sys

csv_path, email_filter = sys.argv[1:]
cfg_path = os.path.expanduser('~/.codexbar/config.json')

# 读取已导入的邮箱
imported = set()
if os.path.exists(cfg_path):
    with open(cfg_path, 'r', encoding='utf-8') as fh:
        cfg = json.load(fh)
    for provider in cfg.get('providers', []):
        if provider.get('kind') == 'openai_oauth':
            for account in provider.get('accounts', []):
                email = account.get('email')
                if email:
                    imported.add(email)

with open(csv_path, 'r', encoding='utf-8', newline='') as fh:
    rows = list(csv.DictReader(fh))

for row in rows:
    email = row.get('email', '')
    password = row.get('password', '')
    status = (row.get('status') or '').strip().lower()
    if not email or not password:
        continue
    if email_filter and email != email_filter:
        continue
    if status == 'invalid':
        continue
    if email in imported:
        continue
    print(email)
    print(password)
PY
}

require_cmd python3
source "$CSV_SHADOW_HELPER"
codex_csv_begin_mutation "$CSV_PATH"

# 获取待登录账号列表
PENDING_LIST="$(get_pending_accounts)"
if [[ -z "$PENDING_LIST" ]]; then
  if [[ -n "$EMAIL_FILTER" ]]; then
    printf 'ℹ️  CSV 中没有待登录的账号匹配 %s\n' "$EMAIL_FILTER"
  else
    printf 'ℹ️  CSV 中没有待登录的账号（可能已全部导入）\n'
  fi
  printf 'BATCH_IMPORTED_COUNT=0\n'
  printf 'BATCH_FAILED_COUNT=0\n'
  exit 0
fi

# 解析为数组
mapfile -t ALL_PENDING < <(printf '%s\n' "$PENDING_LIST")
TOTAL_AVAILABLE=$(( ${#ALL_PENDING[@]} / 2 ))

# 确定本次要登录的数量
if [[ -z "$COUNT" ]]; then
  LOGIN_COUNT=$TOTAL_AVAILABLE
else
  LOGIN_COUNT="$COUNT"
  if (( LOGIN_COUNT > TOTAL_AVAILABLE )); then
    LOGIN_COUNT=$TOTAL_AVAILABLE
  fi
fi

printf '========================================\n'
printf '🔐 开始批量登录 Codexbar\n'
printf '📋 本次登录: %s / 可用: %s\n' "$LOGIN_COUNT" "$TOTAL_AVAILABLE"
printf '⏱  登录间隔: %s 秒\n' "$INTERVAL_SECS"
printf '📁 CSV 路径: %s\n' "$CSV_PATH"
printf '========================================\n'

IMPORTED=0
FAILED=0

for i in $(seq 0 $((LOGIN_COUNT - 1))); do
  idx=$(( i * 2 ))
  email="${ALL_PENDING[$idx]}"
  password="${ALL_PENDING[$idx + 1]}"
  item=$(( i + 1 ))

  printf '\n[%s/%s] 登录: %s\n' "$item" "$LOGIN_COUNT" "$email"

  if output="$(CODEX_CSV_PATH="$CSV_PATH" CODEX_CSV_EMAIL="$email" OPENAI_EMAIL="$email" OPENAI_PASSWORD="$password" "$IMPORT_SCRIPT" 2>&1)"; then
    printf '%s\n' "$output"
    codex_csv_begin_mutation "$CSV_PATH"
    update_csv_status "$email" "$password" "success"
    codex_csv_sync_shadow "$CSV_PATH"
    printf '✅ [%s/%s] 导入成功\n' "$item" "$LOGIN_COUNT"
    ((IMPORTED++))
  else
    EXIT_CODE=$?
    FAILURE_CATEGORY="$(printf '%s\n' "$output" | sed -n 's/^IMPORT_FAILURE_CATEGORY=//p' | tail -n 1)"
    printf '%s\n' "$output" >&2
    codex_csv_begin_mutation "$CSV_PATH"
    update_csv_status "$email" "$password" "import_failed"
    codex_csv_sync_shadow "$CSV_PATH"
    if [[ -n "$FAILURE_CATEGORY" ]]; then
      printf '⚠️  失败分类: %s\n' "$FAILURE_CATEGORY" >&2
    fi
    printf '❌ [%s/%s] 导入失败 (exit %d)\n' "$item" "$LOGIN_COUNT" "$EXIT_CODE" >&2
    ((FAILED++))
  fi

  # 间隔
  if (( i < LOGIN_COUNT - 1 )); then
    printf '⏳ 等待 %s 秒...\n' "$INTERVAL_SECS"
    sleep "$INTERVAL_SECS"
  fi
done

printf '\n========================================\n'
printf '📊 登录完成\n'
printf '✅ 成功: %s\n' "$IMPORTED"
printf '❌ 失败: %s\n' "$FAILED"
printf '📁 结果已写入: %s\n' "$CSV_PATH"
printf '========================================\n'

if (( FAILED > 0 )); then
  exit 1
fi
